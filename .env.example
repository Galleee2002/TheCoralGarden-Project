# =============================================================================
# TheCoralGarden — Variables de entorno
# Copiar este archivo como .env.local para desarrollo local
# En producción (Vercel), configurar estas variables en el dashboard
# =============================================================================

# -----------------------------------------------------------------------------
# Base de datos — Supabase / PostgreSQL
# Obtener desde: Supabase Dashboard → Project Settings → Database → Connection string
# Para Vercel (serverless): usar la URL con pooler (puerto 6543)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# -----------------------------------------------------------------------------
# Supabase Auth
# Obtener desde: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# -----------------------------------------------------------------------------
# MercadoPago
# Obtener desde: https://www.mercadopago.com.ar/developers/panel/app
# Usar credenciales de PRODUCCIÓN para deploy final
# -----------------------------------------------------------------------------
MERCADOPAGO_ACCESS_TOKEN="APP_USR-..."
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY="APP_USR-..."

# -----------------------------------------------------------------------------
# Cloudinary — Subida de imágenes
# Obtener desde: https://cloudinary.com/console
# Crear un upload preset público en Settings → Upload → Upload presets
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="[cloud-name]"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="[upload-preset-name]"

# -----------------------------------------------------------------------------
# URL base de la aplicación
# En producción: la URL de Vercel (ej: https://thecoralgardenok.vercel.app)
# Necesaria para el webhook de MercadoPago y redirecciones de checkout
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
