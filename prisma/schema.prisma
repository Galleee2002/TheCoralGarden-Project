datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  products    Product[]
  createdAt   DateTime  @default(now())
}

model SiteSetting {
  key   String @id
  value String
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String
  price       Decimal     @db.Decimal(10, 2)
  stock       Int         @default(0)
  shippingWeightGrams Int @default(0)
  shippingHeightCm   Int @default(0)
  shippingWidthCm    Int @default(0)
  shippingLengthCm   Int @default(0)
  images         String[]
  specifications String[]
  featured       Boolean     @default(false)
  active      Boolean     @default(true)
  category    Category    @relation(fields: [categoryId], references: [id])
  categoryId  String
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Order {
  id               String      @id @default(cuid())
  status           OrderStatus @default(PENDING)
  customerName     String
  customerEmail    String
  customerPhone    String
  customerStreet   String
  customerStreetNumber String?
  customerFloor    String?
  customerApartment String?
  customerCity     String
  customerProvince String
  customerZip      String
  subtotal         Decimal     @db.Decimal(10, 2)
  shippingCost     Decimal     @db.Decimal(10, 2)
  shippingMethod   String      @default("correo_argentino_home")
  shippingQuoteProvider String @default("correo_argentino")
  shippingQuotedAt DateTime?
  shippingRatePayload Json?
  shippingExternalId String?
  total            Decimal     @db.Decimal(10, 2)
  mpPreferenceId   String?
  mpPaymentId      String?
  shippingCarrier          String?
  shippingDeliveryType     String?
  shippingProductType      String?
  shippingProductName      String?
  shippingAgency           String?
  shippingAgencyName       String?
  shippingDeliveryTimeMin  String?
  shippingDeliveryTimeMax  String?
  shippingQuoteValidTo     DateTime?
  shippingExternalOrderId  String?
  shippingImportStatus     String?
  shippingImportError      String?
  shippingImportedAt       DateTime?
  shippingTrackingNumber   String?
  shippingTrackingLastEvent String?
  shippingTrackingLastSyncAt DateTime?
  shippingTrackingRaw      Json?
  shippingEmailSentAt      DateTime?
  items            OrderItem[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model OrderItem {
  id          String  @id @default(cuid())
  order       Order   @relation(fields: [orderId], references: [id])
  orderId     String
  product     Product @relation(fields: [productId], references: [id])
  productId   String
  productName String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}
